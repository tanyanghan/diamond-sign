MINECRAFT_DIR=full_path_to_minecraft_server

# --- Chat platforms ---
# Comma-separated; the bot serves all of them at once (default: telegram).
# e.g. CHAT_PLATFORMS=telegram,slack
CHAT_PLATFORMS=telegram
# Telegram (required if CHAT_PLATFORMS includes telegram) — from @BotFather.
BOT_TOKEN=your_token_here
# Slack (required if CHAT_PLATFORMS includes slack) — Socket Mode, no public URL.
# SLACK_BOT_TOKEN is the xoxb-… bot token; SLACK_APP_TOKEN is the xapp-… app-level
# token with connections:write. See the README for the app manifest.
#SLACK_BOT_TOKEN=xoxb-...
#SLACK_APP_TOKEN=xapp-...

# Server edition: "java" (default) or "bedrock".
SERVER_EDITION=java

# --- Java only (RCON) ---
RCON_PASSWORD=your_rcon_password_here
# Optional RCON connection overrides (defaults shown):
#RCON_HOST=localhost
#RCON_PORT=25575

# --- Bedrock only (no RCON; commands injected via tmux/screen) ---
# The tmux/screen session hosting the server (byobu uses tmux or screen).
# Leave blank to auto-detect the first live session.
MUX_SESSION=
# Captured server stdout to tail (Bedrock has no logs/latest.log).
# Defaults to MINECRAFT_DIR/console.log. Launch BDS so its stdout is captured,
# e.g. inside your byobu/tmux/screen session:
#   ./bedrock_server 2>&1 | tee -a console.log
#CONSOLE_LOG=
# Command to relaunch BDS after a per-player restore's stop->edit->restart.
# Defaults to: cd <MINECRAFT_DIR> && ./bedrock_server 2>&1 | tee -a console.log
# Override only for a non-standard launch.
#MUX_START_CMD=
# Bedrock chat + death events via the bedrock_pack behavior pack (see
# bedrock_pack/INSTALL.md). BEDROCK_SCRIPT_EVENTS ingests death markers and
# enables /deaths + /death_summary; CHAT_RELAY relays in-game chat to the chat
# platforms. Both default off.
#BEDROCK_SCRIPT_EVENTS=false
#CHAT_RELAY=false

# --- Backups (both editions) ---
BACKUP_SCHEDULE=daily
BACKUP_HOUR=4
BACKUP_DIR=~/minecraft_backup
BACKUP_COPY_CMD=
INCREMENTAL_BACKUP_ENABLED=false
INCREMENTAL_INTERVAL_MINUTES=15
